{% extends 'base.html.twig' %}

{% block title %}{{ 'lesson.edit'| trans }} | {{ lesson.name }} | {{ lesson.course.name }}{% endblock %}
{% block h1 %}{{ 'lesson.edit'| trans }} "{{ lesson.name }}"{% endblock %}

{% block action %}
    <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="btn btn-outline-danger me-2">{{ 'lesson.back_to'| trans }}</a>
    {{ include('lesson/_delete_form.html.twig') }}
{% endblock %}

{% block body %}
    {{ include('lesson/_form.html.twig', {'button_label': 'update'}) }}
{% endblock %}
