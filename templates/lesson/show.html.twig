{% extends 'base.html.twig' %}

{% block title %}{{ lesson.course.name }} | {{ lesson.name }}{% endblock %}
{% block h1 %}{{ lesson.name }}{% endblock %}

{% block action %}
    {% if is_granted('ROLE_SUPER_ADMIN') %}
        <a class="btn btn-primary me-2"  href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">{{ 'lesson.edit'| trans }}</a>
        {{ include('lesson/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}

{% block body %}
    <div class="mb-4">
        {{ 'lesson.attached_to'| trans }} <a href="{{ path('app_course_show', {'code': lesson.course.code}) }}">{{ lesson.course.name }}</a>
    </div>
    <div class="row">
        <div class="col-8">
            <p>{{ lesson.content }}</p>
        </div>
        <div class="mt-4">
            <a href="{{ path('app_course_show', {'code':lesson.course.code}) }}" class="btn btn-outline-primary me-2">{{ 'lesson.back'| trans }}</a>
            {% if nextLesson %}
                <a href="{{ path('app_lesson_show', {'id': nextLesson.id}) }}" class="btn btn-primary">{{ 'lesson.next'| trans }}</a>
            {% else %}
                <button class="btn btn-primary" disabled>{{ 'lesson.next'| trans }}</button>
            {% endif %}
        </div>
    </div>
{% endblock %}
