{% extends 'base.html.twig' %}

{% block title %}{{ lesson.course.name }} | {{ lesson.name }}{% endblock %}
{% block h1 %}{{ lesson.name }}{% endblock %}

{% block action %}
    <a class="btn btn-primary me-2"  href="{{ path('app_lesson_edit', {'id': lesson.id}) }}">{{ 'lesson.edit'| trans }}</a>
    {{ include('lesson/_delete_form.html.twig') }}
{% endblock %}

{% block body %}
    <div class="mb-4">
        {{ 'lesson.attached_to'| trans }} <a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.name }}</a>
    </div>
    <div class="row">
        <div class="col-8">
            <p>{{ lesson.content }}</p>
        </div>
        <div class="mt-4">
            <a href="{{ path('app_course_show', {'id':lesson.course.id}) }}" class="btn btn-outline-primary me-2">{{ 'lesson.back'| trans }}</a>
            <a href="#" class="btn btn-primary">{{ 'lesson.next'| trans }}</a>
        </div>
    </div>
{% endblock %}
