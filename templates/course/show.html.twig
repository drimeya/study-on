{% extends 'base.html.twig' %}

{% block title %}{{ course.name }}{% endblock %}
{% block h1 %} {{ course.name }}{% endblock %}

{% block action %}
    {% if is_granted('ROLE_SUPER_ADMIN') %}
        <a class="btn btn-primary me-2" href="{{ path('app_course_edit', {'code': course.code}) }}">{{ 'course.edit'|trans }}</a>
        {{ include('course/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}

{% block body %}
    {% if billingError %}
        <div class="alert alert-warning">Сервис временно недоступен. Информация о стоимости курса недоступна.</div>
    {% endif %}

    <div class="row mb-3">
        <div class="col-8">
            <p>{{ course.description }}</p>
        </div>
        <div class="col-4 text-end">
            {# --- Блок оплаты --- #}
            {% if not billingError and billingCourse is not null %}
                {% if billingCourse.type == 'free' %}
                    <span class="badge bg-success fs-6">Бесплатно</span>
                {% elseif paymentInfo %}
                    {# Курс уже оплачен #}
                    {% if billingCourse.type == 'rent' and paymentInfo.expiresAt %}
                        <div class="alert alert-info py-2 mb-0">
                            Арендовано до {{ paymentInfo.expiresAt|date('d.m.Y H:i') }}
                        </div>
                    {% else %}
                        <div class="alert alert-success py-2 mb-0">Куплено</div>
                    {% endif %}
                {% elseif is_granted('IS_AUTHENTICATED_FULLY') %}
                    {# Курс не оплачен, пользователь авторизован #}
                    {% set canAfford = balance is not null and balance >= billingCourse.price %}

                    {% if billingCourse.type == 'rent' %}
                        <button type="button" class="btn btn-outline-primary"
                                {% if not canAfford %}disabled title="Недостаточно средств (баланс: {{ balance }} ₽)"{% endif %}
                                data-bs-toggle="modal" data-bs-target="#payModal">
                            Арендовать за {{ billingCourse.price }} ₽
                        </button>
                    {% else %}
                        <button type="button" class="btn btn-primary"
                                {% if not canAfford %}disabled title="Недостаточно средств (баланс: {{ balance }} ₽)"{% endif %}
                                data-bs-toggle="modal" data-bs-target="#payModal">
                            Купить за {{ billingCourse.price }} ₽
                        </button>
                    {% endif %}

                    {% if balance is not null %}
                        <div class="text-muted small mt-1">Ваш баланс: {{ balance }} ₽</div>
                    {% endif %}
                {% else %}
                    {# Гость видит цену, но не может купить #}
                    <a href="{{ path('app_login') }}" class="btn btn-outline-secondary">
                        Войти для покупки ({{ billingCourse.price }} ₽)
                    </a>
                {% endif %}
            {% endif %}
        </div>
    </div>

    <div class="row mb-4 pb-2 mt-4 border-bottom border-2">
        <div class="col-8">
            <h2 class="h4">{{ 'course.lesson.list'|trans }}</h2>
        </div>
    </div>

    {# Курс заблокирован: платный, не оплачен, не администратор #}
    {% set courseLocked = not billingError
        and billingCourse is not null
        and not billingCourse.isFree()
        and not paymentInfo
        and not is_granted('ROLE_SUPER_ADMIN') %}

    {% if courseLocked %}
        <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-lock-fill flex-shrink-0" viewBox="0 0 16 16">
                <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
            </svg>
            <div>
                Уроки доступны после оплаты курса.
                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                    Воспользуйтесь кнопкой выше, чтобы приобрести курс.
                {% else %}
                    <a href="{{ path('app_login') }}">Войдите</a>, чтобы приобрести курс.
                {% endif %}
            </div>
        </div>
    {% endif %}

    {% for lesson in lessons %}
    <div class="row mb-2 pb-2 border-bottom lesson-item">
        <div class="col-8">
            {% if courseLocked %}
                <span class="text-muted">Урок {{ loop.index }}. {{ lesson.name }}</span>
                <span class="ms-1 text-secondary" title="Требуется оплата">🔒</span>
            {% else %}
                <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}" class="d-block link-primary link-offset-2">Урок {{ loop.index }}. {{ lesson.name }}</a>
            {% endif %}
        </div>
        <div class="col-4">
            {% if is_granted('ROLE_SUPER_ADMIN') %}
                <div class="d-flex justify-content-end">
                    <a href="{{ path('app_lesson_edit', {'id': lesson.id}) }}" class="btn btn-outline-primary me-2">{{ 'lesson.edit'|trans }}</a>
                    {{ include('lesson/_delete_form.html.twig') }}
                </div>
            {% endif %}
        </div>
    </div>
    {% else %}
        <p>{{ 'lesson.empty'|trans }}</p>
    {% endfor %}

    <div class="mt-4">
        {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('app_lesson_new', {'id': course.id}) }}" class="btn btn-primary me-2">{{ 'lesson.add'|trans }}</a>
        {% endif %}
        <a class="btn btn-outline-primary" href="{{ path('app_course_index') }}">{{ 'course.list.back'|trans }}</a>
    </div>

    {# ===== Bootstrap Modal подтверждения оплаты ===== #}
    {% if billingCourse is not null and not billingCourse.isFree() and not paymentInfo and is_granted('IS_AUTHENTICATED_FULLY') %}
    <div class="modal fade" id="payModal" tabindex="-1" aria-labelledby="payModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="payModalLabel">Подтверждение оплаты</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    {% if billingCourse.type == 'rent' %}
                        Вы хотите <strong>арендовать на 1 неделю</strong> курс «{{ course.name }}»
                        за <strong>{{ billingCourse.price }} ₽</strong>?
                    {% else %}
                        Вы хотите <strong>купить</strong> курс «{{ course.name }}»
                        за <strong>{{ billingCourse.price }} ₽</strong>?
                    {% endif %}
                    {% if balance is not null %}
                        <div class="text-muted mt-2 small">Ваш текущий баланс: {{ balance }} ₽</div>
                    {% endif %}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <form action="{{ path('app_course_pay', {'code': course.code}) }}" method="post" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('pay_course_' ~ course.code) }}">
                        <button type="submit" class="btn btn-primary">Подтвердить оплату</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}
