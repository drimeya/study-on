<form method="post"
      action="{{ path('app_course_delete', {'id': course.id}) }}"
      onsubmit="return confirm('{{ 'base.delete.confirm'| trans }}');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
    <button class="btn btn-danger">{{ 'course.delete'|trans }}</button>
</form>
