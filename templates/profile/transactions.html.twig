{% extends 'base.html.twig' %}

{% block title %}История транзакций{% endblock %}
{% block h1 %}История транзакций{% endblock %}

{% block body %}
    {% if error %}
        <div class="alert alert-danger">{{ error }}</div>
    {% else %}
        {% if transactions is empty %}
            <p class="text-muted">Транзакций пока нет.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Дата и время</th>
                            <th>Тип</th>
                            <th>Курс</th>
                            <th class="text-end">Сумма</th>
                            <th>Срок действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for transaction in transactions %}
                            <tr>
                                <td>{{ transaction.id }}</td>
                                <td>{{ transaction.createdAt|date('d.m.Y H:i') }}</td>
                                <td>
                                    {% if transaction.type == 'deposit' %}
                                        <span class="badge bg-success">Пополнение</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Списание</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if transaction.courseCode %}
                                        <a href="{{ path('app_course_show', {'code': transaction.courseCode}) }}">
                                            {{ transaction.courseCode }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    {% if transaction.type == 'deposit' %}
                                        <span class="text-success">+{{ transaction.amount }} ₽</span>
                                    {% else %}
                                        <span class="text-danger">-{{ transaction.amount }} ₽</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if transaction.expiresAt %}
                                        {{ transaction.expiresAt|date('d.m.Y') }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    {% endif %}

    <div class="mt-3">
        <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary">← Назад в профиль</a>
    </div>
{% endblock %}
